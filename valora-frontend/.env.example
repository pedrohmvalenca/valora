# Base URL da API VALORA backend.
#
# Em dev local com backend rodando em localhost:8080 -> http://localhost:8080/api/v1
# Em dev sem backend (mock-only)                     -> /api/v1 (resolve contra :5173 e falha — ok para Story 1.2)
# Em prod (Vercel)                                   -> /api/v1 (caminho relativo; vercel.json faz proxy
#                                                       transparente para o backend Render via rewrite — mantém
#                                                       cookie httpOnly como first-party e evita bloqueio de
#                                                       cookies de terceiros pelos navegadores modernos)
VITE_API_BASE=http://localhost:8080/api/v1
