# .env.example — TEMPLATE para valora-backend
# Copiar para .env e preencher. NUNCA commitar .env.

# ============================================================
# Database (obrigatório)
# Local com Docker compose padrão:
DATABASE_URL=jdbc:postgresql://localhost:5433/valora_local?user=valora_dev&password=valora_dev

# Local sem Docker — apontar para Postgres remoto (Supabase/Neon/Render free tier):
# DATABASE_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres?user=postgres.xxx&password=yyy&sslmode=require

# ============================================================
# JWT (obrigatório a partir da Story 1.3)
# Gerar secret real: openssl rand -base64 64
# Mínimo: 256 bits (44 chars base64). NUNCA reusar entre ambientes.
JWT_SECRET=
JWT_EXPIRATION_MINUTES=240

# ============================================================
# Profile Spring Boot
# Local: local | Homol: homol | Prod: prod
SPRING_PROFILES_ACTIVE=local

# ============================================================
# Porta HTTP do backend (opcional)
# Default: 8080. Setar apenas se houver conflito local com outro serviço
# (ex.: MiniTool ShadowMaker, IIS Express, outro Spring Boot rodando).
# Diagnóstico do conflito: `netstat -ano | findstr :8080` (Windows) /
# `lsof -i :8080` (Mac/Linux).
# SERVER_PORT=8081

# ============================================================
# SMTP (preparação Story 2.5 — pode ficar vazio em Story 1.1)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@valora.example.com

# ============================================================
# CORS (Story 1.3 — frontend Vite roda em 5173)
# CSV de origens permitidas. Wildcard '*' é incompatível com cookie de credentials.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ============================================================
# JWT cookie Secure flag (Story 1.3)
# Default: true (homol/prod sobre HTTPS). Setar false APENAS em dev local sem HTTPS.
# JWT_COOKIE_SECURE=true
